# Copy to .env and fill in when you connect a broker (use python-dotenv in your runner if you like).
# Never commit real secrets.

# --- Yahoo / defaults (optional; see src/settings.py) ---
# SYMBOL=RELIANCE.NS
# INITIAL_CASH=100000
# MAX_POSITION_PCT=10
# DAILY_LOSS_LIMIT_PCT=2
# STOP_LOSS_PCT=1.5

# --- Zerodha Kite Connect ---
# KITE_API_KEY=
# KITE_API_SECRET=          # only for kite-token step; do not ship to VPS logs
# KITE_ACCESS_TOKEN=        # expires daily; regenerate via kite-token
# Example LTP key (quotes): NSE:RELIANCE — verify in instruments master
Copy-Item ".env.example" ".env"